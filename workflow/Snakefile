# BulkRNAPipe main Snakefile
include: 'rules/common.smk'
include: 'rules/qc.smk'
include: 'rules/trim.smk'
include: 'rules/align.smk'
include: 'rules/quantify.smk'
include: 'rules/deseq2.smk'
include: 'rules/gsea.smk'
include: 'rules/go.smk'
include: 'rules/compare_contrasts.smk'

# Define the pipeline working directory
workdir: config['User']['output_dir']

rule BulkRNAPipe_output:
    input:
        # ── Raw QC ────────────────────────────────────────────────────────────
        "QC/raw/multiqc/multiqc_report.html" if QC_RAW else [],
        # ── Trimming ──────────────────────────────────────────────────────────
        expand("trim/{sample}/{sample}_val_1.fq.gz", sample=SAMPLES) if TRIM and PAIRED else [],
        expand("trim/{sample}/{sample}_trimmed.fq.gz", sample=SAMPLES) if TRIM and not PAIRED else [],
        # ── Post-trim QC ──────────────────────────────────────────────────────
        "QC/trimmed/multiqc/multiqc_report.html" if QC_TRIMMED else [],
        # ── Alignment ─────────────────────────────────────────────────────────
        expand("align/{sample}/{sample}.Aligned.sortedByCoord.out.bam.bai", sample=SAMPLES) if ALIGN else [],
        "QC/align/multiqc/multiqc_report.html" if ALIGN else [],
        # ── Quantification ────────────────────────────────────────────────────
        "quantify/counts.txt" if QUANTIFY else [],
        # ── Differential expression ───────────────────────────────────────────
        expand("deseq2/{contrast}/results.csv", contrast=CONTRASTS) if DESEQ2 else [],
        expand("deseq2/{contrast}/volcano_proteomics.pdf", contrast=CONTRASTS) if DESEQ2 and PROTEOMICS else [],
        # ── PCA ───────────────────────────────────────────────────────────────
        "deseq2/pca.pdf" if DESEQ2 else [],
        # ── GSEA ─────────────────────────────────────────────────────────────
        expand("gsea/{contrast}/{collection}_results.csv",
               contrast=CONTRASTS, collection=GSEA_COLLECTIONS) if GSEA else [],
        # ── GO enrichment ─────────────────────────────────────────────────────
        expand("go/{contrast}/go_{ont}_{dir}_results.csv",
               contrast=CONTRASTS,
               ont=[o.lower() for o in GO_ONTOLOGIES],
               dir=["up", "down"]) if GOENRICH else [],
        # ── Contrast comparisons ──────────────────────────────────────────────
        expand("gsea_compare/{comparison}/delta_nes_summary.csv",
               comparison=CONTRAST_COMPARISONS) if GSEA and CONTRAST_COMPARISONS else [],
    default_target: True
    localrule: True
